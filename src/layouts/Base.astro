---
import '../styles/global.scss';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Daggerdale Chronicle — A D&D campaign journal spanning 20+ years.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <title>{title} — The Daggerdale Chronicle</title>
  </head>
  <body>
    <header class="page-header">
      <a href={base} class="home-link">The Daggerdale Chronicle</a>
      <a href={`${base}search/`} class="search-button" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Search
      </a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
