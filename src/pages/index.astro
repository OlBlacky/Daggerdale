---
import '../styles/global.scss';
import { getCollection } from 'astro:content';
import { getChronicleByChapter, chapterDescriptions } from '../lib/stories';

const chapters = await getChronicleByChapter();
const appendixEntries = await getCollection('appendix');
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="The Daggerdale Chronicle — An account of the major political and religious happenings in and around Daggerdale from 1367–1483 DR." />
    <link rel="icon" href={`${base}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <title>The Daggerdale Chronicle</title>
  </head>
  <body class="home">
    <a href={`${base}search/`} class="search-button" aria-label="Search">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      Search
    </a>
    <main class="title-page" data-pagefind-body>
      <header class="hero">
        <h1>The Daggerdale Chronicle</h1>
        <p class="subtitle">An account of the major political and religious happenings<br />in and around Daggerdale from 1367–1483 DR</p>
        <p class="author">Compiled by Grafton Fitzdecker, Independent Scholar</p>
      </header>

      <nav class="toc">
        <h2>The Chronicle</h2>

        {[...chapters.entries()].map(([chNum, { title, entries }]) => (
          <div class="toc-chapter">
            {chNum === 0 ? (
              <ul>
                {entries.map((entry) => (
                  <li><a href={`${base}chronicle/${entry.id}/`}>{entry.data.title}</a></li>
                ))}
              </ul>
            ) : (
              <details>
                <summary>
                  {title}
                  {chapterDescriptions[chNum] && (
                    <span class="chapter-era">{chapterDescriptions[chNum]}</span>
                  )}
                  <span class="entry-count">{entries.length} entries</span>
                </summary>
                {chNum <= 2 ? (
                  <p class="chapter-missing"><em>Unwritten — source materials are now difficult to find.</em></p>
                ) : (
                  <ul>
                    {entries.map((entry) => (
                      <li><a href={`${base}chronicle/${entry.id}/`}>{entry.data.title}</a></li>
                    ))}
                  </ul>
                )}
              </details>
            )}
          </div>
        ))}

        <h2>Appendices</h2>
        <ul>
          {appendixEntries
            .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
            .map((entry) => (
              <li><a href={`${base}appendix/${entry.id}/`}>{entry.data.title}</a></li>
          ))}
        </ul>

        <p class="search-link">
          <a href={`${base}search/`}>Search the Chronicle</a>
        </p>
      </nav>
    </main>
  </body>
</html>
