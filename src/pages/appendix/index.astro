---
import Base from '../../layouts/Base.astro';
import { getSortedAppendix } from '../../lib/appendix';

const entries = await getSortedAppendix();
const base = import.meta.env.BASE_URL;
---

<Base title="Appendix">
  <h1>Appendix</h1>
  <ul class="card-grid" data-pagefind-body>
    {entries.map((entry) => (
      <li>
        <a class="card" href={`${base}appendix/${entry.id}/`}>
          <h2>{entry.data.title}</h2>
        </a>
      </li>
    ))}
  </ul>
</Base>
